{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trade-capture.schema.json",
  "title": "Trade Capture DTO Schemas",
  "type": "object",
  "definitions": {
    "CaptureTradeRequest": {
      "type": "object",
      "required": [
        "sourceSystem",
        "tradeExternalId",
        "accountId",
        "bookId",
        "securityId",
        "direction",
        "quantity",
        "price",
        "tradeDate"
      ],
      "properties": {
        "sourceSystem": { "type": "string" },
        "tradeExternalId": { "type": "string" },
        "accountId": { "type": "string" },
        "bookId": { "type": "string" },
        "securityId": { "type": "string" },
        "direction": { "type": "string", "enum": ["BUY", "SELL"] },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "tradeDate": { "type": "string", "format": "date" },
        "settlementDate": { "type": "string", "format": "date" },
        "productId": { "type": "string" },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "CaptureTradeAcceptedResponse": {
      "type": "object",
      "required": ["ingestionId", "status", "acceptedAt"],
      "properties": {
        "ingestionId": { "type": "string" },
        "status": { "type": "string", "enum": ["ACCEPTED"] },
        "acceptedAt": { "type": "string", "format": "date-time" },
        "lifecycleInstructionType": { "type": "string" }
      }
    },
    "CaptureTradeBatchRequest": {
      "type": "object",
      "required": ["sourceSystem", "trades"],
      "properties": {
        "sourceSystem": { "type": "string" },
        "trades": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/CaptureTradeRequest" }
        }
      }
    },
    "CaptureTradeBatchAcceptedResponse": {
      "type": "object",
      "required": ["batchId", "status", "acceptedCount"],
      "properties": {
        "batchId": { "type": "string" },
        "status": { "type": "string", "enum": ["ACCEPTED"] },
        "acceptedCount": { "type": "integer" },
        "rejectedCount": { "type": "integer" }
      }
    },
    "TradeIngestionStatusResponse": {
      "type": "object",
      "required": ["ingestionId", "status"],
      "properties": {
        "ingestionId": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["ACCEPTED", "QUEUED", "SENT_TO_LIFECYCLE", "FAILED"]
        },
        "lastUpdatedAt": { "type": "string", "format": "date-time" },
        "failureReason": { "type": "string" }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "required": ["code", "message", "timestamp"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "VALIDATION_ERROR",
            "DUPLICATE_IDEMPOTENCY_KEY",
            "LIFECYCLE_DISPATCH_ERROR",
            "INGESTION_NOT_FOUND",
            "INTERNAL_ERROR"
          ]
        },
        "message": { "type": "string" },
        "correlationId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
