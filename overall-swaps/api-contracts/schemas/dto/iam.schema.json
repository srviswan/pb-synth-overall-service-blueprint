{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "iam.schema.json",
  "title": "IAM DTO Schemas",
  "type": "object",
  "definitions": {
    "TokenValidationRequest": {
      "type": "object",
      "required": ["token"],
      "properties": {
        "token": { "type": "string" }
      }
    },
    "EntitlementCheckRequest": {
      "type": "object",
      "required": ["userId", "functionName"],
      "properties": {
        "userId": { "type": "string" },
        "functionName": { "type": "string" },
        "accountId": { "type": "string" },
        "bookId": { "type": "string" },
        "securityId": { "type": "string" }
      }
    }
  }
}
